# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Virtual environments
myenv/
venv/
env/

# Data files
data/
*.csv

# Artifacts are required for inference deployment
# Keep them available for Render/GitHub deployment.
!artifacts/
!artifacts/**

# Model files
*.pkl
*.joblib

# Numpy arrays
*.npy

# Logs
logs/
*.log

# OS files
.DS_Store
Thumbs.db

# IDE files
.vscode/
.idea/

# Environment variables
.env

# Deployment artifacts must override generic file ignores above
!artifacts/*/data_transformation/encoder.pkl
!artifacts/*/data_transformation/preprocessor.pkl
!artifacts/*/model/model.pkl
